apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
localAPIEndpoint:
  advertiseAddress: {{ hostvars[control_plane_ip | default(groups['control_plane'][0])].ansible_host }}
nodeRegistration:
  criSocket: unix:///run/containerd/containerd.sock
  kubeletExtraArgs:
    - name: cgroup-driver
      value: systemd
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
controlPlaneEndpoint: "{{ hostvars[control_plane_ip | default(groups['control_plane'][0])].ansible_host }}:6443"
clusterName: {{ cluster_name }}
networking:
  podSubnet: {{ pod_subnet }}
  serviceSubnet: {{ service_subnet }}
# For single control-plane we don't set controlPlaneEndpoint
